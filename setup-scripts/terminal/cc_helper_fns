########################################################################################
# Claude Code (claude -p) helper functions: works in zsh (macOS) and bash (Linux)
########################################################################################
# Requires: Claude Code CLI (`claude`) on PATH.
# Optional: `uv` for `pycode -x`, `glow` for formatted output.
# Tip: pipe any output through `| glow -w 100` for rendered markdown.
#
# Install: save as ~/.cc_helper_fns.sh, then add to ~/.zshrc AND/OR ~/.bashrc:
#   [[ -f ~/.cc_helper_fns.sh ]] && source ~/.cc_helper_fns.sh
# This file must be sourced, not executed.
# Multi-word arguments do NOT need quoting: `cmd find all py files` works.

# Fail fast at source time if the claude CLI is missing.
if ! command -v claude >/dev/null 2>&1; then
    echo "cc_helper_fns: claude CLI not found on PATH, helpers not loaded" >&2
    return 1
fi

########################################################################################
# Shell and OS detection (the only non-portable parts live here)
########################################################################################

if [[ -n "$ZSH_VERSION" ]]; then
    _CC_SHELL="zsh"
elif [[ -n "$BASH_VERSION" ]]; then
    _CC_SHELL="bash"
else
    echo "cc_helper_fns: unsupported shell (need zsh or bash), helpers not loaded" >&2
    return 1
fi

case "$(uname -s)" in
    Darwin) _CC_OS="macOS (BSD userland: BSD find, sed, stat, etc.)" ;;
    Linux)  _CC_OS="Linux (GNU userland: GNU find, sed, stat, etc.)" ;;
    *)      _CC_OS="a Unix-like system" ;;
esac

# _cc_edit_line <command>: put a command on the interactive prompt for review.
# zsh: print -z pushes into the line editor buffer.
# bash: read -e -i pre-fills an editable readline prompt, then runs on Enter.
if [[ "$_CC_SHELL" == "zsh" ]]; then
    _cc_edit_line() { print -z -- "$1"; }
else
    _cc_edit_line() {
        local edited
        read -e -r -i "$1" -p "run> " edited || return 1
        [[ -n "$edited" ]] && { history -s "$edited"; eval "$edited"; }
    }
fi

# Config: default-if-unset, so values exported before sourcing this file win.
# Two model tiers, aliases resolve to the latest version for your provider.
: "${CC_FAST_MODEL:=haiku}"     # quick one-shots: cmd, regex, cron, git, pipes, images
: "${CC_SMART_MODEL:=sonnet}"   # heavier reasoning: explain, pycode, review
: "${CC_EFFORT:=low}"           # reasoning effort for all helpers
: "${CC_MAX_INPUT_BYTES:=100000}"  # inlined files and diffs are truncated past this

CC_CMD_SYSTEM_PROMPT="You are inside a terminal on $_CC_OS. Output only the raw shell command(s) appropriate for this OS. No formatting, no code blocks, no explanations, no extra text."

CC_EXPLAIN_SYSTEM_PROMPT="You are a senior software engineer and teacher.
Instructions:
When given source code or a file, analyze it and answer the question clearly and concisely.
Identify the file's purpose, flow, and key functions or commands when relevant.
Reference function names, variables, or line numbers if useful.
Be accurate, practical, and minimal, no fluff.
When the input is a general concept or question, explain it directly in clear, concise terms."

CC_IMAGE_SYSTEM_PROMPT="You are a helpful vision assistant. Analyze the provided image and answer the question accurately and concisely."

CC_PYCODE_SYSTEM_PROMPT="Generate minimal Python scripts with PEP 723 inline metadata. Start every script with:
# /// script
# requires-python = \">=3.11\"
# dependencies = [
#     \"package-name\",
# ]
# ///
Rules:
List third-party packages in dependencies. Use empty dependencies = [] if only stdlib.
Write minimal, direct code. No try/except unless explicitly required.
No defensive coding, no unnecessary error handling, no verbose comments.
Output only raw Python. No explanations. No markdown."

########################################################################################
# Private runner: every helper funnels through this one invocation.
########################################################################################

# _cc <model> <system_prompt> <user_prompt...>
# Stdin, if piped, flows through to claude untouched.
_cc() {
    local model="$1" sys="$2"
    shift 2
    claude -p "$*" \
        --model "$model" \
        --effort "$CC_EFFORT" \
        --max-turns 1 \
        --system-prompt "$sys"
}

# _cc_read <file>: prints file contents, truncated to CC_MAX_INPUT_BYTES with a warning.
_cc_read() {
    local size
    size=$(wc -c < "$1")
    if (( size > CC_MAX_INPUT_BYTES )); then
        echo "warning: $1 is ${size} bytes, truncating to ${CC_MAX_INPUT_BYTES}" >&2
        head -c "$CC_MAX_INPUT_BYTES" "$1"
    else
        cat "$1"
    fi
}

# _cc_in_git_repo: succeeds inside a git work tree, prints an error otherwise.
_cc_in_git_repo() {
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: not inside a git repository." >&2
        return 1
    fi
}

########################################################################################
# Help
########################################################################################

