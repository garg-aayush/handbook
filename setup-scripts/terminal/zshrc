# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Powerlevel10k theme (installed under $ZSH/custom/themes by setup.sh)
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins (external ones cloned into $ZSH/custom/plugins by setup.sh)
plugins=(git zsh-autosuggestions zsh-syntax-highlighting web-search fzf)

source $ZSH/oh-my-zsh.sh

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# zoxide smarter cd (uncomment if you want `z` jumping)
# command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"

# uv — Python package/project manager (installed via Brewfile). Shell completions.
if command -v uv >/dev/null 2>&1; then
  eval "$(uv generate-shell-completion zsh)"
  eval "$(uvx --generate-shell-completion zsh)"
fi

# gh copilot aliases (only if gh + the copilot extension are installed)
command -v gh >/dev/null 2>&1 && eval "$(gh copilot alias -- zsh 2>/dev/null)"

# direnv — per-directory env (switches gh CLI identity per repo; see dev-tips/git-multiple-accounts.md)
command -v direnv >/dev/null 2>&1 && eval "$(direnv hook zsh)"

# PATHs
export PATH="$PATH:$HOME/.local/bin"                       # pipx
export PATH="/opt/homebrew/opt/llvm/bin:$PATH"             # llvm
export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="$PATH:$HOME/.lmstudio/bin"                    # LM Studio CLI
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"     # Antigravity
export PATH="$HOME/.opencode/bin:$PATH"                    # opencode

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# iTerm2 shell integration
test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

