# Ignore env files with secrets
.env

# Ignore spec story files
**/.specstory/

# Ignore cursor index files
**/.cursorindexingignore

# Track only the curated skills under .claude/skills/, ignore everything else
# under .claude/ (settings.local.json, hooks, caches, ad-hoc local skills).
/.claude/*
!/.claude/skills/
!/.claude/statusline.sh
/.claude/skills/ship/
**/.DS_Store
# Ignore plots generated by the time-series example scripts
time-series/**/*.png
